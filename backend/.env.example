# Backend Environment Variables
# Copy this to .env before running the backend

SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# ─── Database ──────────────────────────────────
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
DB_URL=jdbc:mysql://localhost:3306/healthcare_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true

# ─── JWT ───────────────────────────────────────
JWT_SECRET=replace_with_a_strong_32_byte_or_longer_secret
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ─── Gemini AI ──────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-lite:generateContent

# ─── OpenRouter / OpenAI-compatible ─────────────
OPENAI_API_KEY=your_openrouter_api_key
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# ─── Razorpay ──────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─── Notifications ─────────────────────────────
# dev  = print to console (no real email/SMS)
# prod = send real email via Gmail + SMS via Twilio
NOTIFICATION_MODE=dev
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# ─── Mail (only needed if NOTIFICATION_MODE=prod) ──
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ─── Twilio (only needed if NOTIFICATION_MODE=prod) ─
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ─── Frontend / CORS ────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000