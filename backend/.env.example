# Backend Environment Variables
# Copy this to .env before running the backend

SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# ─── Database ──────────────────────────────────
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
DB_URL=jdbc:mysql://localhost:3306/healthcare_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true

# ─── JWT ───────────────────────────────────────
JWT_SECRET=
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ─── Gemini AI ──────────────────────────────────
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-lite:generateContent

# ─── OpenRouter / OpenAI-compatible ─────────────
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# ─── Razorpay ──────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Notifications ─────────────────────────────
# dev  = print to console (no real email/SMS)
# prod = send real email via Gmail + SMS via Twilio
NOTIFICATION_MODE=dev
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# ─── Mail (only needed if NOTIFICATION_MODE=prod) ──
MAIL_USERNAME=
MAIL_PASSWORD=

# ─── Twilio (only needed if NOTIFICATION_MODE=prod) ─
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Frontend / CORS ────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
